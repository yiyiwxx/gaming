# 环境变量
# 复制此文件为 .env 并填写实际值

# 数据库
DATABASE_URL="file:./prisma/dev.db"

# 应用 URL（部署时修改为实际域名）
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 子路径部署（本地留空）
NEXT_PUBLIC_BASE_PATH=""

# OpenAI API（可选，不填则使用本地 fallback）
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# LoL Esports API Key（可选）
LOLESPORTS_API_KEY=""

# VLR 时区
VLR_TIMEZONE="Asia/Shanghai"
